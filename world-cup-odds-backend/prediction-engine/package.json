    "backtest": "python -m app.backtest"
  },
  "python_dependencies": [
    "fastapi>=0.115.0",
    "uvicorn>=0.30.0",
    "psycopg2-binary>=2.9.9",
    "sqlalchemy>=2.0.0",
    "pandas>=2.2.0",
    "numpy>=1.26.0",
    "scipy>=1.12.0",
    "scikit-learn>=1.5.0",
    "catboost>=1.2.0",
    "pydantic>=2.6.0"
  ]
}
